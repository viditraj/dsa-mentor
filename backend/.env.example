# ── LLM Provider Selection ──────────────────────────────────────────
# Which LLM backend to use. Options: "nvidia", "ollama", "dell"
LLM_PROVIDER=nvidia

# ── Retry / Back-off (applies to all providers) ────────────────────
# LLM_MAX_RETRIES=3
# LLM_BACKOFF_SEC=1.0

# ── NVIDIA NIM Configuration ───────────────────────────────────────
# Get an API key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ENABLE_THINKING=true

# ── Ollama (Local) Configuration ───────────────────────────────────
# Install Ollama: https://ollama.com
# Pull a model:   ollama pull qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Dell AIA Gateway Configuration ─────────────────────────────────
DELL_LLM_MODEL=gpt-oss-120b
DELL_LLM_BASE_URL=https://aia.gateway.dell.com/genai/dev/v1

# Authentication — set USE_SSO=true for browser-based Dell SSO login
USE_SSO=true

# Or use OAuth client credentials (set USE_SSO=false):
# CLIENT_ID=your_client_id
# CLIENT_SECRET=your_client_secret
# ENABLE_TOKEN_REFRESH_AT_SERVER_SIDE=false
